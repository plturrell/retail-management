# ─── GCP Project ──────────────────────────────────────────────
GCP_PROJECT_ID=project-b41c0c0d-6eea-4e9d-a78

# ─── Database (Cloud SQL or local) ───────────────────────────
# Local dev with Docker Compose:
DATABASE_URL=postgresql+asyncpg://retailsg:retailsg@localhost:5432/retailsg
# Cloud SQL (via Cloud SQL Auth Proxy on localhost:5432):
# DATABASE_URL=postgresql+asyncpg://retailsg:<PASSWORD>@localhost:5432/retailsg

# ─── Firebase / Auth ─────────────────────────────────────────
FIREBASE_PROJECT_ID=project-b41c0c0d-6eea-4e9d-a78
# Path to your Firebase Admin service account JSON key:
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# ─── Gemini AI ────────────────────────────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
GEMINI_API_KEY=

# ─── App ──────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]
ENVIRONMENT=development
