# ─── GCP Project ──────────────────────────────────────────────
GCP_PROJECT_ID=project-b41c0c0d-6eea-4e9d-a78

# ─── Database (Cloud SQL via Auth Proxy) ─────────────────────
# Run: cloud-sql-proxy project-b41c0c0d-6eea-4e9d-a78:asia-southeast1:retailsg --port 5432
DATABASE_URL=postgresql+asyncpg://retailsg:<PASSWORD>@localhost:5432/retailsg

# ─── Firebase / Auth ─────────────────────────────────────────
FIREBASE_PROJECT_ID=project-b41c0c0d-6eea-4e9d-a78
# Path to your Firebase Admin service account JSON key:
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# ─── Gemini AI ────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_USE_VERTEX_AI=true
VERTEX_AI_LOCATION=global

# ─── App ──────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]
ENVIRONMENT=development

# ─── Snowflake ────────────────────────────────────────────────
# Account identifier: NDKTJHV-MH65474 (org: NDKTJHV, account: MH65474)
# Server URL:  NDKTJHV-MH65474.snowflakecomputing.com
# Cloud:       GCP  |  Edition: Standard
#
# Run scripts/setup_snowflake.sql as VICTORIAENSO (ACCOUNTADMIN) once to
# create the RETAILSG_SVC service user, RETAILSG_ROLE, RETAILSG_WH,
# RETAILSG database, and ANALYTICS / ETL schemas before starting locally.
#
SNOWFLAKE_ACCOUNT=NDKTJHV-MH65474
SNOWFLAKE_USER=RETAILSG_SVC
SNOWFLAKE_PASSWORD=<see GCP Secret Manager: retailsg-snowflake-password>
SNOWFLAKE_DATABASE=RETAILSG
SNOWFLAKE_SCHEMA=ANALYTICS
SNOWFLAKE_WAREHOUSE=RETAILSG_WH
SNOWFLAKE_ROLE=RETAILSG_ROLE
SNOWFLAKE_ETL_SCHEMA=ETL
