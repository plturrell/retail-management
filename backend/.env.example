# ─── GCP Project ──────────────────────────────────────────────
GCP_PROJECT_ID=victoriaensoapp

# ─── Database (Cloud SQL via Auth Proxy) ─────────────────────
# Run: cloud-sql-proxy victoriaensoapp:asia-southeast1:retailsg --port 5432
DATABASE_URL=postgresql+asyncpg://retailsg:<PASSWORD>@localhost:5432/retailsg

# ─── Firebase / Auth ─────────────────────────────────────────
FIREBASE_PROJECT_ID=victoriaensoapp
# Path to your Firebase Admin service account JSON key:
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# ─── Gemini AI ────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_USE_VERTEX_AI=true
VERTEX_AI_LOCATION=global

# ─── DeepSeek AI ──────────────────────────────────────────────
# Get from: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-c38a121bf7674e9083d8x203dd24c0a51

# ─── TiDB Cloud (MySQL-compatible) ───────────────────────────
# Get the connection string from TiDB Cloud Console → Cluster → Connect.
# Replace <password> with the freshly-rotated key (NEVER commit the real key).
# TiDB Serverless requires TLS; the asyncmy driver picks up system CAs by default.
# TIDB_DATABASE_URL=mysql+asyncmy://<user>:<password>@<host>:4000/retailsg?ssl=true
TIDB_DATABASE_URL=
# Optional explicit CA bundle (only needed if your OS doesn't ship system roots
# in a place asyncmy can find — usually unnecessary on Linux containers).
TIDB_SSL_CA=

# ─── App ──────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]
ENVIRONMENT=development

# ─── Snowflake ────────────────────────────────────────────────
# Account identifier: NDKTJHV-MH65474 (org: NDKTJHV, account: MH65474)
# Server URL:  NDKTJHV-MH65474.snowflakecomputing.com
# Cloud:       GCP  |  Edition: Standard
#
# Run scripts/setup_snowflake.sql as VICTORIAENSO (ACCOUNTADMIN) once to
# create the RETAILSG_SVC service user, RETAILSG_ROLE, RETAILSG_WH,
# RETAILSG database, and ANALYTICS / ETL schemas before starting locally.
#
SNOWFLAKE_ACCOUNT=NDKTJHV-MH65474
SNOWFLAKE_USER=RETAILSG_SVC
SNOWFLAKE_PASSWORD=<see GCP Secret Manager: retailsg-snowflake-password>
SNOWFLAKE_DATABASE=RETAILSG
SNOWFLAKE_SCHEMA=ANALYTICS
SNOWFLAKE_WAREHOUSE=RETAILSG_WH
SNOWFLAKE_ROLE=RETAILSG_ROLE
SNOWFLAKE_ETL_SCHEMA=ETL

# ─── AI artifacts (GCS) ───────────────────────────────────────
AI_GCS_BUCKET=victoriaensoapp-ai-artifacts

# ─── CAG / NEC Jewel POS SFTP ──────────────────────────────────────────────
# Credentials provided by NEC/CAG during onboarding (see
# docs/CAG - NEC Retail POS Onboarding Guides/Import and Export Sales Interface
# /[Latest] CAG NEC - SFTP guide v1.1.pdf). The tenant folder is the 6/7-digit
# Customer No. assigned by Jewel/CAG.
CAG_SFTP_HOST=
CAG_SFTP_PORT=22
CAG_SFTP_USER=
CAG_SFTP_PASSWORD=
CAG_SFTP_KEY_PATH=
CAG_SFTP_KEY_PASSPHRASE=
CAG_SFTP_TENANT_FOLDER=

# Cloud Scheduler → Cloud Run OIDC for unattended CAG pushes.
# The default store id is NEC's 5-digit Store ID, not the app's JEWEL-01 code.
CAG_SCHEDULER_SA_EMAIL=
CAG_SCHEDULER_AUDIENCE=
CAG_SCHEDULED_PUSH_DEFAULT_TENANT=
CAG_SCHEDULED_PUSH_DEFAULT_STORE_ID=80001
