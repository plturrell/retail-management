{
  "name": "tax-build",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.27.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "test": "pnpm -r --if-present test",
    "db:generate": "pnpm --filter @tax-build/db db:generate",
    "db:migrate": "pnpm --filter @tax-build/db db:migrate"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "better-sqlite3": "^12.8.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
