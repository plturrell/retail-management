rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Vault Staging rules
    match /ocr_staging_vault/{document} {
      // allow read, write if the user is authenticated
      // (a real world scenario might strictly check custom claims like `request.auth.token.role == 'manager'`)
      allow read, write: if request.auth != null;
    }

    match /{document=**} {
      allow read, write: if false; // Deny all by default
    }
  }
}
